root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 4

[*.{py}]
indent_size = 4
max_line_length = 100

[*.{cpp,h,cs}]
indent_style = tab
indent_size = 4

[*.{json,yml,yaml,md}]
indent_size = 2

[*.md]
trim_trailing_whitespace = false

[*.{uproject,uplugin}]
indent_style = tab
